rules_version = '2';

// Mirrors src/lib/firestore/schema.ts — keep collection names and the
// owner/member/platform_admin role model in sync with that module.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function callerDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function callerRole() {
      return callerDoc().role;
    }

    function callerOrgId() {
      return callerDoc().organizationId;
    }

    function isPlatformAdmin() {
      return isSignedIn() && callerRole() == 'platform_admin';
    }

    function isMemberOfOrg(orgId) {
      return isSignedIn() && callerOrgId() == orgId;
    }

    function isOwnerOfOrg(orgId) {
      return isMemberOfOrg(orgId) && callerRole() == 'owner';
    }

    // User docs are created and updated server-side (Admin SDK) during
    // onboarding, so the Admin SDK bypasses these rules entirely; the
    // client can only read its own doc.
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isPlatformAdmin());
      allow write: if false;
    }

    match /organizations/{orgId} {
      allow read: if isMemberOfOrg(orgId) || isPlatformAdmin();

      // Owners may edit organization profile fields, but never the
      // subscription or usage fields — those are Admin-SDK-only so a
      // client can never grant itself a plan or reset its own usage.
      allow update: if (isOwnerOfOrg(orgId) &&
                          request.resource.data.subscription == resource.data.subscription &&
                          request.resource.data.usage == resource.data.usage) ||
                        isPlatformAdmin();
      allow create, delete: if isPlatformAdmin();

      match /aiSystems/{systemId} {
        allow read: if isMemberOfOrg(orgId) || isPlatformAdmin();
        allow write: if isOwnerOfOrg(orgId) || isPlatformAdmin();
      }

      match /assessments/{assessmentId} {
        allow read: if isMemberOfOrg(orgId) || isPlatformAdmin();
        allow write: if isOwnerOfOrg(orgId) || isPlatformAdmin();
      }

      match /documents/{documentId} {
        allow read: if isMemberOfOrg(orgId) || isPlatformAdmin();
        allow write: if isOwnerOfOrg(orgId) || isPlatformAdmin();
      }

      match /article50Artifacts/{artifactId} {
        allow read: if isMemberOfOrg(orgId) || isPlatformAdmin();
        allow write: if isOwnerOfOrg(orgId) || isPlatformAdmin();
      }

      match /trainingRecords/{recordId} {
        allow read: if isMemberOfOrg(orgId) || isPlatformAdmin();
        allow write: if isOwnerOfOrg(orgId) || isPlatformAdmin();
      }

      // Append-only audit trail. The client can never write or delete —
      // only the Admin SDK writes here, and it bypasses these rules, so
      // this is intentionally "if false" rather than an owner check.
      match /auditLog/{entryId} {
        allow read: if isMemberOfOrg(orgId) || isPlatformAdmin();
        allow create, update, delete: if false;
      }

      // Invites carry invitee email addresses and are looked up by token
      // from an unauthenticated visitor (the invite link), so there is no
      // client-side access pattern that needs a rule here at all — every
      // read and write goes through an Admin SDK API route.
      match /invites/{inviteId} {
        allow read, write: if false;
      }
    }

    // Marketing newsletter signups. Written only via the Admin SDK
    // (/api/newsletter/subscribe), so this is deny-all for the same reason
    // invites is: there is no legitimate client-side access pattern.
    match /newsletterSubscribers/{docId} {
      allow read, write: if false;
    }

    // Risk-scan leads. Written by /api/risk-scan/email-report and read by
    // the /report/[id] page, both via the Admin SDK — the public report
    // page is server-rendered, never a client-side Firestore read, so this
    // stays deny-all like the other lead-capture collections.
    match /leads/{docId} {
      allow read, write: if false;
    }

    // P13 consultant marketplace — every page that reads these (admin
    // consultant/expert-review dashboards, the consultant portal, the
    // org-facing expert-reviews page) is a server component going through
    // the Admin SDK, and every write goes through an API route. No
    // legitimate client-side access pattern, so deny-all here too.
    match /consultants/{uid} {
      allow read, write: if false;
    }
    match /consultantInvites/{inviteId} {
      allow read, write: if false;
    }
    match /expertReviews/{reviewId} {
      allow read, write: if false;
    }
    match /platformAuditLog/{entryId} {
      allow read, write: if false;
    }

    // P14 automations — regulatory news is written by the RSS/Claude cron
    // and read by server-rendered dashboard/regulatory-updates pages;
    // cron run history is admin-only and read via the Admin SDK. Same
    // no-client-access reasoning as the rest of this file.
    match /regulatoryUpdates/{updateId} {
      allow read, write: if false;
    }
    match /cronRuns/{runId} {
      allow read, write: if false;
    }
    match /mrrSnapshots/{date} {
      allow read, write: if false;
    }
  }
}
